[Unit]
Description=Ollama Telegram Chat Bot
After=network.target

[Service]
Type=simple
User=your_user_name
WorkingDirectory=/absolute/path/to/your/project
EnvironmentFile=/absolute/path/to/your/project/.env
ExecStart=/absolute/path/to/.venv/bin/python3 /absolute/path/to/your/project/bot/chat_bot.py
Restart=always

[Install]
WantedBy=multi-user.target